{
  "name": "aidescribe",
  "version": "0.0.3",
  "description": "Generate jj change descriptions with AI",
  "keywords": [
    "ai",
    "cli",
    "commit",
    "jj",
    "jujutsu",
    "vcs"
  ],
  "homepage": "https://github.com/pguilbert/aidescribe#readme",
  "bugs": {
    "url": "https://github.com/pguilbert/aidescribe/issues"
  },
  "license": "MIT",
  "author": "Paul Guilbert",
  "repository": {
    "type": "git",
    "url": "https://github.com/pguilbert/aidescribe.git"
  },
  "bin": {
    "aidescribe": "dist/cli.mjs"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "scripts": {
    "build": "pkgroll --minify",
    "typecheck": "tsc",
    "dev": "tsx src/cli.ts",
    "prepack": "pnpm run build",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@clack/prompts": "^1.0.1",
    "cleye": "^2.2.1",
    "execa": "^9.6.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "kolorist": "^1.8.0",
    "oxfmt": "^0.35.0",
    "oxlint": "^1.50.0",
    "pkgroll": "^2.26.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=22"
  }
}
